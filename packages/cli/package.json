{
  "name": "formgrid-cli",
  "version": "1.0.0",
  "description": "CLI tool for managing and running Formgrid locally with Docker — just like Supabase CLI.",
  "type": "module",
  "bin": {
    "formgrid": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepare": "pnpm run build",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "formgrid",
    "cli",
    "docker",
    "forms",
    "api",
    "self-hosted",
    "form-backend",
    "monorepo"
  ],
  "author": "Allen Jones",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allenarduino/formgrid.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/allenarduino/formgrid/issues"
  },
  "homepage": "https://github.com/allenarduino/formgrid#readme",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "execa": "^8.0.0",
    "ora": "^7.0.0"
  },
  "devDependencies": {
    "tsup": "^7.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}


