{
  "name": "@formgrid/api",
  "version": "1.0.0",
  "private": true,
  "description": "FormGrid API - Backend service for form endpoint generation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "ts-node-dev --respawn --transpile-only src/queueWorker.ts",
    "worker:prod": "node dist/queueWorker.js",
    "prisma:dev": "prisma migrate dev --name init",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watch",
    "test:coverage": "jest --runInBand --coverage",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:e2e:watch": "jest --config jest.e2e.config.js --watch",
    "test:e2e:coverage": "jest --config jest.e2e.config.js --coverage",
    "test:email": "ts-node src/test-email.ts",
    "test:spam": "ts-node src/test-spam-protection.ts",
    "cleanup": "ts-node src/scripts/file-cleanup.ts",
    "setup:minio": "ts-node src/scripts/setup-minio.ts",
    "setup:s3": "ts-node src/scripts/setup-s3.ts",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "formgrid",
    "api",
    "forms",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@google-cloud/storage": "^7.17.2",
    "@prisma/client": "^6.15.0",
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.0.0",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.6",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.6",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "resend": "^6.0.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^7.0.1",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.3",
    "jest": "^30.1.3",
    "prisma": "^6.15.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
